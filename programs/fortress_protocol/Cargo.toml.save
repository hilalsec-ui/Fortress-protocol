[package]
name = "fortress_lottery"
version = "0.1.0"
description = "Fortress Protocol Lottery Program"
edition = "2021"

[lib]
crate-type = ["cdylib", "lib"]
name = "fortress_lottery"

[features]
no-entrypoint = []
no-idl = []
no-log-ix-name = []
cpi = ["no-entrypoint"]
default = ["init-if-needed"]
init-if-needed = ["anchor-lang/init-if-needed"]
# The line below is commented out to prevent the proc-macro2 / SourceFile build error
# idl-build = ["anchor-lang/idl-build", "anchor-spl/idl-build"]
custom-heap = []
custom-panic = []
anchor-debug = []

[dependencies]
anchor-lang = "0.30.1"
anchor-spl = "0.30.1"

# Pyth removed temporarily due to edition2024 dependency conflict
# For randomness, we use blockhash-based pseudo-randomness instead
# pyth-solana-receiver-sdk = "0.3.0"

# Dev dependencies commented out to avoid edition2024 conflicts
# [dev-dependencies]
# solana-program-test = "1.18.22"
# solana-sdk = "1.18.22"
