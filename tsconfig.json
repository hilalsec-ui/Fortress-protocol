{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "mocha", "chai"]
  },
  "include": ["scripts/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "target"]
}
